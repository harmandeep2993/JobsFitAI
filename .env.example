# Copy this file to backend/.env and fill in your values.
# Never commit backend/.env - it is gitignored.

# === Required ===
# Signs JWT auth tokens. Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# LLM providers (OpenAI is the default; Groq is the automatic fallback)
OPENAI_API_KEY=
GROQ_API_KEY=

# Adzuna job board credentials (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# === Access control ===
# Comma-separated emails granted the admin role (app-wide LLM settings switch)
ADMIN_EMAILS=

# When set, registration requires this code (invite-only beta). Unset = open registration.
INVITE_CODE=

# === Production only ===
# Set to "production" to enforce production requirements (startup fails without JWT_SECRET)
# APP_ENV=production

# Comma-separated CORS origins; defaults to the localhost dev servers when unset
# ALLOWED_ORIGINS=https://yourdomain.com

# Cloud SQLite (optional - falls back to local data/jobsfitai.db when unset)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
